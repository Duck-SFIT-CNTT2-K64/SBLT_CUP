generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PLAYER
}

enum TournamentStatus {
  UPCOMING
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum StageType {
  QUALIFIER
  SEMI_1
  SEMI_2
  FINAL
  WARMUP
}

enum StageStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum GameStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum AnnouncementType {
  GENERAL
  SCHEDULE_CHANGE
  RULE_UPDATE
  RESULT
}

enum DisputeStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
}

enum PredictionStatus {
  OPEN
  LOCKED
  SCORED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  name              String
  emailVerified     DateTime?
  role              Role      @default(PLAYER)
  avatar            String?
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  player   Player?
  accounts Account[]

  passwordResetTokens    PasswordResetToken[]
  auditLogs              AuditLog[]
  predictions            Prediction[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  comments               Comment[]
  reactions              Reaction[]
  pushSubscriptions      PushSubscription[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Player {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ign       String   @unique  // D-01: Enforce uniqueness at DB level
  rank      String?
  discord   String?
  phone     String?
  isGuest   Boolean  @default(false)
  createdAt DateTime @default(now())

  registrations Registration[]
  groupPlayers  GroupPlayer[]
  gameResults   GameResult[]
  prizes        Prize[]
  disputes      Dispute[]         @relation("DisputeSubmitter")
  predictionsRank1 PredictionEntry[] @relation("PredRank1")
  predictionsRank2 PredictionEntry[] @relation("PredRank2")
  predictionsRank3 PredictionEntry[] @relation("PredRank3")
  predictionsRank4 PredictionEntry[] @relation("PredRank4")
}

model Tournament {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  season      Int              @unique
  description String?
  status      TournamentStatus @default(UPCOMING)
  regStart    DateTime
  regEnd      DateTime
  startDate   DateTime
  endDate     DateTime
  maxPlayers  Int              @default(64)
  prizePool   Int              @default(10000000)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  registrations Registration[]
  stages        Stage[]
  prizes        Prize[]
  announcements Announcement[]
  disputes      Dispute[]

  @@index([status])
  @@index([startDate])
}

model Registration {
  id           String             @id @default(cuid())
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String
  player       Player             @relation(fields: [playerId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(PENDING)
  registeredAt DateTime           @default(now())
  checkedIn    Boolean            @default(false)
  checkInTime  DateTime?
  updatedAt    DateTime           @default(now()) @updatedAt

  @@unique([tournamentId, playerId])
  @@index([tournamentId, status])
  @@index([playerId])
}

model Stage {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  stageType    StageType
  stageOrder   Int
  date         DateTime
  startTime    String
  totalGames   Int         @default(3)
  status       StageStatus @default(SCHEDULED)

  groups      Group[]
  predictions Prediction[]

  @@unique([tournamentId, stageType])
  @@index([tournamentId])
}

model Group {
  id        String @id @default(cuid())
  stageId   String
  stage     Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  name      String
  groupOrder Int

  players    GroupPlayer[]
  games      Game[]
  predictions PredictionEntry[]

  @@index([stageId])
}

model GroupPlayer {
  id         String  @id @default(cuid())
  groupId    String
  group      Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  playerId   String
  player     Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  totalPoints Int    @default(0)
  finalRank  Int?

  @@unique([groupId, playerId])
  @@index([playerId])
}

model Game {
  id         String     @id @default(cuid())
  groupId    String
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  gameNumber Int
  status     GameStatus @default(SCHEDULED)
  startTime  DateTime?
  endTime    DateTime?

  results GameResult[]
  disputes Dispute[]

  @@unique([groupId, gameNumber])
  @@index([groupId])
  @@index([status])
}

model GameResult {
  id        String @id @default(cuid())
  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  placement Int
  points    Int

  @@unique([gameId, playerId])
  @@index([playerId])
}

model Prize {
  id           String   @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rank         Int
  amount       Int
  description  String
  playerId     String?
  player       Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)
  paid         Boolean  @default(false)
  paidAt       DateTime?

  @@unique([tournamentId, rank])
  @@index([tournamentId])
}

model Announcement {
  id           String           @id @default(cuid())
  tournamentId String?
  tournament   Tournament?      @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  title        String
  content      String
  type         AnnouncementType @default(GENERAL)
  createdAt    DateTime         @default(now())

  @@index([createdAt])
  @@index([tournamentId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, used])
  @@index([expiresAt])
}

model Dispute {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  gameId       String?
  game         Game?         @relation(fields: [gameId], references: [id], onDelete: SetNull)
  submittedBy  String
  player       Player        @relation("DisputeSubmitter", fields: [submittedBy], references: [id], onDelete: Cascade)
  reason       String
  description  String
  status       DisputeStatus @default(PENDING)
  adminNote    String?
  attachments  Json?
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@index([tournamentId])
  @@index([status])
  @@index([submittedBy])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum NotificationType {
  TOURNAMENT_UPDATE
  MATCH_RESULT
  PREDICTION_SCORED
  ANNOUNCEMENT
  REGISTRATION_STATUS
  CHECK_IN_REMINDER
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled         Boolean  @default(true)
  pushEnabled          Boolean  @default(true)
  tournamentUpdates    Boolean  @default(true)
  matchResults         Boolean  @default(true)
  predictionScored     Boolean  @default(true)
  announcements        Boolean  @default(true)
  registrationStatus   Boolean  @default(true)
  checkInReminder      Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

enum CommentType {
  TOURNAMENT
  GAME
  ANNOUNCEMENT
  GLOBAL_CHAT
}

model Comment {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       CommentType
  entityId   String
  content    String
  parentId   String?
  parent     Comment?    @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]   @relation("CommentReplies")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([type, entityId])
  @@index([userId])
  @@index([createdAt])
}

enum ReactionType {
  LIKE
  FIRE
  TROPHY
  CLAP
}

model Reaction {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       ReactionType
  entityType String
  entityId   String
  createdAt  DateTime     @default(now())

  @@unique([userId, entityType, entityId, type])
  @@index([entityType, entityId])
}

model Prediction {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stageId    String
  stage      Stage            @relation(fields: [stageId], references: [id], onDelete: Cascade)
  status     PredictionStatus @default(OPEN)
  totalScore Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  entries PredictionEntry[]

  @@unique([userId, stageId])
  @@index([stageId])
  @@index([userId])
}

model PredictionEntry {
  id           String     @id @default(cuid())
  predictionId String
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  groupId      String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  rank1PlayerId String
  rank1Player   Player @relation("PredRank1", fields: [rank1PlayerId], references: [id], onDelete: Restrict)
  rank2PlayerId String
  rank2Player   Player @relation("PredRank2", fields: [rank2PlayerId], references: [id], onDelete: Restrict)
  rank3PlayerId String
  rank3Player   Player @relation("PredRank3", fields: [rank3PlayerId], references: [id], onDelete: Restrict)
  rank4PlayerId String
  rank4Player   Player @relation("PredRank4", fields: [rank4PlayerId], references: [id], onDelete: Restrict)

  rank1Points Int @default(0)
  rank2Points Int @default(0)
  rank3Points Int @default(0)
  rank4Points Int @default(0)

  @@unique([predictionId, groupId])
  @@index([predictionId])
  @@index([groupId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}
