# Staging Environment Configuration
# Copy to .env.staging and update values for staging

# Database — use a separate staging database
DATABASE_URL="postgresql://user:password@localhost:5432/sblt_cup_staging?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="staging-secret-change-me-in-production"
AUTH_SECRET="staging-secret-change-me-in-production"
NEXTAUTH_URL="http://staging.sblt-cup.local"
AUTH_URL="http://staging.sblt-cup.local"

# Admin emails (comma-separated)
ADMIN_EMAILS="admin@sblt.local"

# Node environment
NODE_ENV="staging"
AUTH_TRUST_HOST=true

# Redis (staging instance)
REDIS_URL="redis://localhost:6379/1"

# Sentry (use a separate DSN for staging)
SENTRY_DSN=""
